[
  {
    "name": "do not merge dependent lets",
    "input": [
      {
        "$project": {
          "a": {
            "$let": {
              "vars": {
                "v1": "$x"
              },
              "in": {
                "$let": {
                  "vars": {
                    "v2": "$$v1"
                  },
                  "in": "$$v2"
                }
              }
            }
          }
        }
      }
    ],
    "expected": [
      {
        "$project": {
          "a": {
            "$let": {
              "vars": {
                "v1": "$x"
              },
              "in": {
                "$let": {
                  "vars": {
                    "v2": "$$v1"
                  },
                  "in": "$$v2"
                }
              }
            }
          }
        }
      }
    ]
  },
  {
    "name": "do not merge independent shadowed variables",
    "input": [
      {
        "$project": {
          "a": {
            "$let": {
              "vars": {
                "v1": "$x"
              },
              "in": {
                "$let": {
                  "vars": {
                    "v1": "$y",
                    "v2": "$$v1"
                  },
                  "in": { "$add": ["$$v1", "$$v2"] }
                }
              }
            }
          }
        }
      }
    ],
    "expected": [
      {
        "$project": {
          "a": {
            "$let": {
              "vars": {
                "v1": "$x"
              },
              "in": {
                "$let": {
                  "vars": {
                    "v1": "$y",
                    "v2": "$$v1"
                  },
                  "in": { "$add": ["$$v1", "$$v2"] }
                }
              }
            }
          }
        }
      }
    ]
  },
  {
    "name": "merge independent lets",
    "input": [
      {
        "$project": {
          "a": {
            "$let": {
              "vars": {
                "v1": "$x"
              },
              "in": {
                "$let": {
                  "vars": {
                    "v2": "$y"
                  },
                  "in": { "$add": ["$$v1", "$$v2"] }
                }
              }
            }
          }
        }
      }
    ],
    "expected": [
      {
        "$project": {
          "a": {
            "$let": {
              "vars": {
                "v1": "$x",
                "v2": "$y"
              },
              "in": { "$add": ["$$v1", "$$v2"] }
            }
          }
        }
      }
    ]
  },
  {
    "name": "merge multiple nested lets that are not direct descendents of an outer let",
    "input": [
      {
        "$project": {
          "a": {
            "$let": {
              "vars": {
                "v1": "$x"
              },
              "in": {
                "$add": [
                  {
                    "$let": {
                      "vars": {
                        "v2": "$y"
                      },
                      "in": {
                        "$add": ["$$v1", "$$v2"]
                      }
                    }
                  },
                  {
                    "$let": {
                      "vars": {
                        "v3": "$z"
                      },
                      "in": {
                        "$add": ["$$v1", "$$v2"]
                      }
                    }
                  }
                ]
              }
            }
          }
        }
      }
    ],
    "expected": [
      {
        "$project": {
          "a": {
            "$let": {
              "vars": {
                "v1": "$x",
                "v2": "$y",
                "v3": "$z"
              },
              "in": {
                "$add": [
                  {
                    "$add": ["$$v1", "$$v2"]
                  },
                  {
                    "$add": ["$$v1", "$$v2"]
                  }
                ]
              }
            }
          }
        }
      }
    ]
  },
  {
    "name": "fully merge multiple levels of independent lets",
    "input": [
      {
        "$project": {
          "a": {
            "$let": {
              "vars": {
                "v1": "$x"
              },
              "in": {
                "$let": {
                  "vars": {
                    "v2": "$y"
                  },
                  "in": {
                    "$let": {
                      "vars": {
                        "v3": "$z",
                        "v4": "$n"
                      },
                      "in": {
                        "$let": {
                          "vars": {
                            "v5": "$m"
                          },
                          "in": {
                            "$add": ["$$v1", "$$v2", "$$v3", "$$v4", "$$v5"]
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    ],
    "expected": [
      {
        "$project": {
          "a": {
            "$let": {
              "vars": {
                "v1": "$x",
                "v2": "$y",
                "v3": "$z",
                "v4": "$n",
                "v5": "$m"
              },
              "in": {
                "$add": ["$$v1", "$$v2", "$$v3", "$$v4", "$$v5"]
              }
            }
          }
        }
      }
    ]
  },
  {
    "name": "partially merge multiple levels of semi-dependent lets",
    "input": [
      {
        "$project": {
          "a": {
            "$let": {
              "vars": {
                "v1": "$x"
              },
              "in": {
                "$let": {
                  "vars": {
                    "v2": "$y"
                  },
                  "in": {
                    "$let": {
                      "vars": {
                        "v3": "$$v1",
                        "v4": "$n"
                      },
                      "in": {
                        "$let": {
                          "vars": {
                            "v5": "$$v2",
                            "v6": "$$v3"
                          },
                          "in": {
                            "$add": ["$$v1", "$$v2", "$$v3", "$$v4", "$$v5", "$$v6"]
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    ],
    "expected": [
      {
        "$project": {
          "a": {
            "$let": {
              "vars": {
                "v1": "$x",
                "v2": "$y",
                "v4": "$n"
              },
              "in": {
                "$let": {
                  "vars": {
                    "v3": "$$v1",
                    "v5": "$$v2"
                  },
                  "in": {
                    "$let": {
                      "vars": {
                        "v6": "$$v3"
                      },
                      "in": {
                        "$add": ["$$v1", "$$v2", "$$v3", "$$v4", "$$v5", "$$v6"]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    ]
  },
  {
    "name": "do not merge let variables in $map that references the as variable",
    "input": [
      {
        "$project": {
          "a": {
            "$let": {
              "vars": {
                "v1": "$x"
              },
              "in": {
                "$map": {
                  "input": [1, 2, 3],
                  "as": "var",
                  "in": {
                    "$let": {
                      "vars": {
                        "v2": { "$add": ["$$var", 2] },
                        "v3": "$y"
                      },
                      "in": { "$add": ["$$v1", "$$v2", "$$v3"] }
                    }
                  }
                }
              }
            }
          }
        }
      }
    ],
    "expected": [
      {
        "$project": {
          "a": {
            "$let": {
              "vars": {
                "v1": "$x",
                "v3": "$y"
              },
              "in": {
                "$map": {
                  "input": [1, 2, 3],
                  "as": "var",
                  "in": {
                    "$let": {
                      "vars": {
                        "v2": { "$add": ["$$var", 2] }
                      },
                      "in": { "$add": ["$$v1", "$$v2", "$$v3"] }
                    }
                  }
                }
              }
            }
          }
        }
      }
    ]
  },
  {
    "name": "do not merge let variables nested in $filter that references the as variable",
    "input": [
      {
        "$project": {
          "a": {
            "$let": {
              "vars": {
                "v1": "$x"
              },
              "in": {
                "$filter": {
                  "input": [1, 2, 3],
                  "as": "var",
                  "cond": {
                    "$let": {
                      "vars": {
                        "v2": { "$add": ["$$var", 2] },
                        "v3": "$y"
                      },
                      "in": {
                        "$eq": [
                          { "$add": ["$$v1", "$$v2"] },
                          "$$v3"
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    ],
    "expected": [
      {
        "$project": {
          "a": {
            "$let": {
              "vars": {
                "v1": "$x",
                "v3": "$y"
              },
              "in": {
                "$filter": {
                  "input": [1, 2, 3],
                  "as": "var",
                  "cond": {
                    "$let": {
                      "vars": {
                        "v2": { "$add": ["$$var", 2] }
                      },
                      "in": {
                        "$eq": [
                          { "$add": ["$$v1", "$$v2"] },
                          "$$v3"
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    ]
  },
  {
    "name": "do not merge let variables nested in $reduce that reference $$this or $$value",
    "input": [
      {
        "$project": {
          "a": {
            "$let": {
              "vars": {
                "v1": "$x"
              },
              "in": {
                "$reduce": {
                  "input": [1, 2, 3],
                  "initialValue": 0,
                  "in": {
                    "$let": {
                      "vars": {
                        "v2": { "$add": ["$$this", 2] },
                        "v3": "$y",
                        "v4": { "$add": ["$$value", 2] }
                      },
                      "in": {
                        "$add": ["$$v1", "$$v2", "$$v3", "$$v4"]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    ],
    "expected": [
      {
        "$project": {
          "a": {
            "$let": {
              "vars": {
                "v1": "$x",
                "v3": "$y"
              },
              "in": {
                "$reduce": {
                  "input": [1, 2, 3],
                  "initialValue": 0,
                  "in": {
                    "$let": {
                      "vars": {
                        "v2": { "$add": ["$$this", 2] },
                        "v4": { "$add": ["$$value", 2] }
                      },
                      "in": {
                        "$add": ["$$v1", "$$v2", "$$v3", "$$v4"]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    ]
  },
  {
    "name": "do not merge let bindings named using the as field from a sibling $map where the name shadows an outer variable",
