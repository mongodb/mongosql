                      "input": [1, 2, 3],
                      "as": "v1",
                      "in": { "$add": ["$$v1", "$$v1"] }
                    }
                  },
                  {
                    "$let": {
                      "vars": {
                        "v1": "$y"
                      },
                      "in": { "$add": ["$$v1", "$$v1"] }
                    }
                  }
                ]
              }
            }
          }
        }
      }
    ],
    "expected": [
      {
        "$project": {
          "a": {
            "$let": {
              "vars": {
                "v1": "$x"
              },
              "in": {
                "$add": [
                  {
                    "$map": {
                      "input": [1, 2, 3],
                      "as": "v1",
                      "in": { "$add": ["$$v1", "$$v1"] }
                    }
                  },
                  {
                    "$let": {
                      "vars": {
                        "v1": "$y"
                      },
                      "in": { "$add": ["$$v1", "$$v1"] }
                    }
                  }
                ]
              }
            }
          }
        }
      }
    ]
  },
  {
    "name": "do not merge let bindings named using the as field from a sibling $filter where the name shadows an outer variable",
    "input": [
      {
        "$project": {
          "a": {
            "$let": {
              "vars": {
                "v1": "$x"
              },
              "in": {
                "$concatArrays": [
                  {
                    "$filter": {
                      "input": [1, 2, 3],
                      "as": "v1",
                      "cond": { "$eq": ["$$v1", "$$v1"] }
                    }
                  },
                  {
                    "$let": {
                      "vars": {
                        "v1": "$y"
                      },
                      "in": ["$$v1", "$$v1"]
                    }
                  }
                ]
              }
            }
          }
        }
      }
    ],
    "expected": [
      {
        "$project": {
          "a": {
            "$let": {
              "vars": {
                "v1": "$x"
              },
              "in": {
                "$concatArrays": [
                  {
                    "$filter": {
                      "input": [1, 2, 3],
                      "as": "v1",
                      "cond": { "$eq": ["$$v1", "$$v1"] }
                    }
                  },
                  {
                    "$let": {
                      "vars": {
                        "v1": "$y"
                      },
                      "in": ["$$v1", "$$v1"]
                    }
                  }
                ]
              }
            }
          }
        }
      }
    ]
  },
  {
    "name": "do not merge let bindings named this and value from let expression that is a sibling of a $reduce where the names shadow outer variables",
