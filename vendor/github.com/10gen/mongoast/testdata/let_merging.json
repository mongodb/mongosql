  {
    "name": "do not merge independent let bindings nested in lazy expressions",
    "input": [
      {
        "$project": {
          "a": {
            "$let": {
              "vars": {
                "v1": "$x"
              },
              "in": {
                "$cond": [
                  { "$lte": ["$y", null] },
                  null,
                  {
                    "$let": {
                      "vars": {
                        "v2": { "$strLenCP": "$y" }
                      },
                      "in": { "$add": ["$$v1", "$$v2"] }
                    }
                  }
                ]
              }
            }
          }
        }
      }
    ],
    "expected": [
      {
        "$project": {
          "a": {
            "$let": {
              "vars": {
                "v1": "$x"
              },
              "in": {
                "$cond": [
                  { "$lte": ["$y", null] },
                  null,
                  {
                    "$let": {
                      "vars": {
                        "v2": { "$strLenCP": "$y" }
                      },
                      "in": { "$add": ["$$v1", "$$v2"] }
                    }
                  }
                ]
              }
            }
          }
        }
      }
    ]
  }
