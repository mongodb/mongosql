              },
              "in": {
                "$add": [
                  {
                    "$reduce": {
                      "input": [1, 2, 3],
                      "initialValue": 0,
                      "in": { "$add": ["$$this", "$$value"] }
                    }
                  },
                  {
                    "$let": {
                      "vars": {
                        "this": "$n",
                        "value": "$m"
                      },
                      "in": { "$add": ["$$this", "$$value"] }
                    }
                  }
                ]
              }
            }
          }
        }
      }
    ],
    "expected": [
      {
        "$project": {
          "a": {
            "$let": {
              "vars": {
                "this": "$x",
                "value": "$y"
              },
              "in": {
                "$add": [
                  {
                    "$reduce": {
                      "input": [1, 2, 3],
                      "initialValue": 0,
                      "in": { "$add": ["$$this", "$$value"] }
                    }
                  },
                  {
                    "$let": {
                      "vars": {
                        "this": "$n",
                        "value": "$m"
                      },
                      "in": { "$add": ["$$this", "$$value" ]}
                    }
                  }
                ]
              }
            }
          }
        }
      }
    ]
  },
