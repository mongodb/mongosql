[
  {
    "name": "ensure optimizer runs DCE and projection compression",
    "input": [
      {
        "$project": {
          "a": "$c",
          "b": "$d"
        }
      },
      {
        "$project": {
          "out": "$a"
        }
      }
    ],
    "expected": [
      {
        "$project": {
          "out": "$c"
        }
      }
    ]
  },
  {
    "name": "ensure optimizer runs Reorder Pass",
    "input": [
      {
        "$sort": {
          "a": 1
        }
      },
      {
        "$match": {
          "a": 1
        }
      }
    ],
    "expected": [
      {
        "$match": {
          "a": 1
        }
      },
      {
        "$sort": {
          "a": 1
        }
      }
    ]
  },
  {
    "name": "ensure optimizer runs PRE",
    "input": [
      {
        "$project": {
          "a": {
            "$sub": [
              {
                "$add": [
                  { "$add": ["$c", "$d"] },
                  { "$add": ["$c", "$d"] },
                  { "$add": ["$c", "$d"] }
                ]
              },
              {
                "$add": [
                  { "$add": ["$c", "$d"] },
                  { "$add": ["$c", "$d"] },
                  { "$add": ["$c", "$d"] }
                ]
              }
            ]
          }
        }
      }
    ],
    "expected": [
      {
        "$project": {
          "a": {
            "$let": {
              "vars": {
                "mongoast__deduplicated__expr__0": { "$add": ["$c", "$d"] }
              },
              "in": {
                "$let": {
                  "vars": {
                    "mongoast__deduplicated__expr__1": {
                      "$add": [
                        "$$mongoast__deduplicated__expr__0",
                        "$$mongoast__deduplicated__expr__0",
                        "$$mongoast__deduplicated__expr__0"
                      ]
                    }
                  },
                  "in": {
                    "$sub": [
                      "$$mongoast__deduplicated__expr__1",
                      "$$mongoast__deduplicated__expr__1"
                    ]
                  }
                }
              }
            }
          }
        }
      }
    ]
  },
  {
      "name": "$regex bug",
      "input": [
        {
            "$match": {
                "$nor": [
                    {"a": {"$regex": "^f.*$","$options": ""}}
                ]
            }
        }
      ],
      "expected": [
        {
            "$match": {
                "$nor": [
                    {"a": {"$regex": "^f.*$","$options": ""}}
                ]
            }
        }
      ]
  }
]
