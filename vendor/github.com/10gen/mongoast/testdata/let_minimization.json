                  "in": { "$add": ["$$v1", "$$v2", "$$v2"] }
                }
              }
            }
          }
        }
      }
    ],
    "expected": [
      {
        "$project": {
          "a": {
            "$let": {
              "vars": {
                "v1": { "$add": ["$x", "$x"] }
              },
              "in": {
                "$let": {
                  "vars": {
                    "v2": { "$add": ["$x", "$$v1"] }
                  },
                  "in": {
                    "$add": [
                      { "$add": ["$$v1", "$$v1"] },
                      "$$v2",
                      "$$v2"
                    ]
                  }
                }
              }
            }
          }
        }
      }
    ]
