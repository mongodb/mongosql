            "$let": {
              "vars": {
                "v1": { "$add": ["$x", "$x"] }
              },
              "in": {
                "$let": {
                  "vars": {
                    "v1": { "$add": ["$$v1", "$$v1"] },
                    "v2": { "$add": ["$x", "$$v1"] }
