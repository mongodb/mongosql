                  "case": {
                    "$eq": [
                      {
                        "$add": [
                          { "$add": [1, 2, 3] },
                          { "$add": [1, 2, 3] }
                        ]
                      },
                      0
                    ]
                  },
                  "then": {
                    "$add": [
                      { "$add": [1, 2, 3] },
                      { "$add": [1, 2, 3] }
                    ]
                  }
                }
              ],
              "default": {
                "$add": [
                  { "$add": [1, 2, 3] },
                  { "$add": [1, 2, 3] }
                ]
              }
            }
          }
        }
