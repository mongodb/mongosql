[
  {
  "name": "redundant $regex should not be pulled out, $let cannot be used in Match Exprs",
  "input": [{
    "$match": {
      "a": {"$regex": "hello", "$options": "i"},
      "b": {"$regex": "hello", "$options": "i"}
    }
  }],
  "expected": [{
    "$match": {
      "a": {"$regex": "hello", "$options": "i"},
      "b": {"$regex": "hello", "$options": "i"}
    }
  }]
  },
  {
    "name": "initial redundancy test",
    "input": [
      {
        "$project": {
          "a": {
            "$sub": [
              {
                "$add": [
                  { "$add": ["$c", "$d"] },
                  { "$add": ["$c", "$d"] },
                  { "$add": ["$c", "$d"] }
                ]
              },
              {
                "$add": [
                  { "$add": ["$c", "$d"] },
                  { "$add": ["$c", "$d"] },
                  { "$add": ["$c", "$d"] }
                ]
              }
            ]
          }
        }
      }
    ],
    "expected": [
      {
        "$project": {
          "a": {
            "$let": {
              "vars": {
                "mongoast__deduplicated__expr__0": { "$add": ["$c", "$d"] }
              },
              "in": {
                "$let": {
                  "vars": {
                    "mongoast__deduplicated__expr__1": {
                      "$add": [
                        "$$mongoast__deduplicated__expr__0",
                        "$$mongoast__deduplicated__expr__0",
                        "$$mongoast__deduplicated__expr__0"
                      ]
                    }
                  },
                  "in": {
                    "$sub": [
                      "$$mongoast__deduplicated__expr__1",
                      "$$mongoast__deduplicated__expr__1"
                    ]
                  }
                }
              }
            }
          }
        }
      }
    ]
  },
  {
    "name": "in match",
    "input": [
      {
        "$match": {
          "$expr": {
            "$sub": [
              { "$add": ["$a", "$b"] },
              { "$add": ["$a", "$b"] }
            ]
          }
        }
      }
    ],
    "expected": [
      {
        "$match": {
          "$expr": {
            "$let": {
              "vars": {
                "mongoast__deduplicated__expr__0": { "$add": ["$a", "$b"] }
              },
              "in": {
                "$sub": [
                  "$$mongoast__deduplicated__expr__0",
                  "$$mongoast__deduplicated__expr__0"
                ]
              }
            }
          }
        }
      }
    ]
  },
  {
    "name": "do not move lets above $maps",
