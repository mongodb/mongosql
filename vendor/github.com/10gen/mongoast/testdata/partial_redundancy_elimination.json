        "$project": {
          "out": {
            "$reduce": {
              "input": "$a.b",
              "initialValue": {
                "$let": {
                  "vars": {
                    "mongoast__deduplicated__expr__0": {
                      "$add": [
                        { "$literal": { "$numberInt": "1" } },
                        { "$literal": { "$numberInt": "2" } }
                      ]
                    }
                  },
                  "in": {
                    "$add": [
                      "$$mongoast__deduplicated__expr__0",
                      "$$mongoast__deduplicated__expr__0"
                    ]
