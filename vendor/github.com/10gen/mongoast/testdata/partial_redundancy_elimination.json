      {
        "$project": {
          "out": {
            "$map": {
              "input": "$a.b",
              "as": "this",
              "in": {
                "$add": [
                  { "$ifNull": ["$$this", null] },
                  { "$ifNull": ["$$this", null] }
                ]
              }
            }
          }
        }
      }
    ],
    "expected": [
      {
        "$project": {
          "out": {
            "$map": {
              "input": "$a.b",
              "as": "this",
              "in": {
                "$let": {
                  "vars": {
                    "mongoast__deduplicated__expr__0": {
                      "$ifNull": ["$$this", null]
                    }
                  },
                  "in": {
                    "$add": [
                      "$$mongoast__deduplicated__expr__0",
                      "$$mongoast__deduplicated__expr__0"
                    ]
                  }
                }
              }
            }
          }
        }
      }
    ]
  },
