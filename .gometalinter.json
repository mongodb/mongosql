{
    "Enable": [
        "deadcode",
        "errcheck",
        "gofmt",
        "goimports",
        "golint",
        "ineffassign",
        "lll",
        "megacheck",
        "misspell",
        "structcheck",
        "unconvert",
        "unparam",
        "varcheck",
        "vet",
        "vetshadow"
    ],
    "Exclude": [
        "parser/"
    ],
    "Linters": {
        "lll": {
            "Command": "lll --maxlength 100 --tabwidth 4",
            "IsFast": true,
            "PartitionStrategy": "files"
        },
        "structcheck": {
            "Command": "structcheck -tags gssapi",
            "Pattern": "^(?P<path>.*?\\.go):(?P<line>\\d+)\\s*(?P<message>.*)$"
        },
        "errcheck": {
            "Command": "errcheck -tags gssapi -ignoretests",
            "Pattern": "^(?P<path>.*?\\.go):(?P<line>\\d+)\\s*(?P<message>.*)$"
        },
        "megacheck": {
            "Command": "megacheck -tags gssapi",
            "Pattern": "^(?P<path>.*?\\.go):(?P<line>\\d+)\\s*(?P<message>.*)$"
        }
    }
}
