schema:
  - db: my_db
    tables:
      - table: tbl_one
        collection: col_one
        pipeline:
          - { $match: { a: { $eq: {"$numberInt":"1"} } } }
        columns:
          - Name: a
            MongoType: int
            SqlName: a
            SqlType: int64
          - Name: b
            MongoType: int
            SqlName: b
            SqlType: int64