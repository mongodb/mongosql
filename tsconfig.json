{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ES2020"],
    "strict": true,
    "outDir": "dist",
    "rootDir": "client/src",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["client/src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
