schema:
- db: viewGeoDb
  tables:
  - table: base
    collection: base
    pipeline: []
    columns:
    - Name: _id
      MongoType: bson.ObjectId
      SqlName: _id
      SqlType: varchar
    - Name: loc.coordinates
      MongoType: geo.2darray
      SqlName: loc.coordinates
      SqlType: numeric[]
    - Name: loc.type
      MongoType: string
      SqlName: loc.type
      SqlType: varchar
